PPEYES_PORT=3000
PPEYES_PLATFORM=linux/amd64
PPEYES_IMAGE_TAG=x86_64
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_API_KEY=replace-with-your-key
GEMINI_MODEL=replace-with-your-model-id

# Optional fallback provider. If Gemini fails, the app will retry with MiniMax.
# For mainland China deployments, you can switch to https://api.minimaxi.com/v1
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_API_KEY=replace-with-your-key
MINIMAX_MODEL=MiniMax-M2.5

# Only enable in environments with custom TLS interception certificates not trusted by Node.
# GEMINI_ALLOW_INSECURE_TLS=1

# Optional but recommended on Vercel for persistent storage.
# If both are set, app state is stored in Supabase instead of local files.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-service-role-key
SUPABASE_WATCHLISTS_TABLE=ppeyes_watchlist_terms
SUPABASE_OPPORTUNITIES_TABLE=ppeyes_saved_opportunities
